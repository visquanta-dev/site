    "nodes": [
      {
        "id": "node-greeting",
        "name": "Greeting & Menu",
        "type": "conversation",
        "instruction": {
          "type": "prompt",
          "text": "Greet the caller warmly and introduce yourself as Mia, Adrian Law's office assistant. Then present the five menu options clearly. Let them know they can say what they need OR press a number on their keypad:\n\n1. Automotive Stars Revenue Recovery Model — for dealerships interested in the AI system that captures missed service calls\n2. Automotive Stars Training Enquiries — for anyone interested in training programs\n3. Tim's Crew — for anything related to Tim's Crew\n4. Next Level Selling — for enquiries about the Next Level Selling program\n5. General enquiry or anything else\n\nSpeak naturally — you don't need to say 'press 1' for every option, just mention it once at the start. Keep it conversational."
        },
        "start_speaker": "agent",
        "edges": [
          {
            "id": "edge-to-router",
            "destination_node_id": "node-menu-router",
            "transition_condition": {
              "type": "prompt",
              "prompt": "Caller has indicated which option they want (either by speaking or DTMF), or said something that clearly fits one of the categories"
            }
          }
        ]
      },
      {
        "id": "node-menu-router",
        "name": "Menu Router",
        "type": "branch",
        "edges": [
          {
            "id": "edge-option-1",
            "destination_node_id": "node-revenue-recovery-check",
            "transition_condition": {
              "type": "prompt",
              "prompt": "Caller selected option 1, Revenue Recovery Model, or mentioned dealership AI, service calls, revenue recovery, automotive AI system, or pressed 1 on keypad"
            }
          },
          {
            "id": "edge-option-2",
            "destination_node_id": "node-training-intro",
            "transition_condition": {
              "type": "prompt",
              "prompt": "Caller selected option 2, Training Enquiries, training programs, or pressed 2 on keypad"
