            "id": "edge-option-5",
            "destination_node_id": "node-general-enquiry-intro",
            "transition_condition": {
              "type": "prompt",
              "prompt": "Caller selected option 5, general enquiry, or pressed 5 on keypad, or their request doesn't clearly fit options 1-4"
            }
          }
        ],
        "else_edge": {
          "id": "edge-clarify",
          "destination_node_id": "node-clarify-menu",
          "transition_condition": {
            "type": "prompt",
            "prompt": "Else - caller's response was unclear or they didn't choose an option"
